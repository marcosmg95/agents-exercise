{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run all tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/", "-v"],
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Run tests with coverage",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/", "-v", "--cov=src/agents_exercise"],
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Run agent tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/test_agent.py", "-v"],
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Run tool tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": ["tests/test_tools.py", "-v"],
            "justMyCode": true,
            "console": "integratedTerminal"
        },
        {
            "name": "Interactive agent",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/interactive.py",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
